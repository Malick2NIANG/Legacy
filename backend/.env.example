# ─────────────────────────────────────────────────────────
#  Legacy Platform — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs réelles
#  NE JAMAIS committer le fichier .env
# ─────────────────────────────────────────────────────────

# ── Sécurité ──────────────────────────────────────────────
SECRET_KEY=change-me-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Base de données ────────────────────────────────────────
# Local Docker :
#   DATABASE_URL=postgresql://ds_user:ds_password@postgres:5432/ds_platform
# Production (Supabase) :
#   DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://ds_user:ds_password@postgres:5432/ds_platform

# ── Redis / Broker Celery ──────────────────────────────────
# Local Docker :
#   REDIS_URL=redis://redis:6379/0
# Production (Upstash) :
#   REDIS_URL=rediss://<user>:<password>@<host>.upstash.io:6379
REDIS_URL=redis://redis:6379/0

# ── Stockage objet ─────────────────────────────────────────
# Local Docker (MinIO) :
#   MINIO_ENDPOINT=minio:9000
#   MINIO_ACCESS_KEY=minioadmin
#   MINIO_SECRET_KEY=minioadmin123
#   MINIO_SECURE=false
# Production (Cloudflare R2) :
#   MINIO_ENDPOINT=<account_id>.r2.cloudflarestorage.com
#   MINIO_ACCESS_KEY=<R2_Access_Key_ID>
#   MINIO_SECRET_KEY=<R2_Secret_Access_Key>
#   MINIO_SECURE=true
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=datasets
MINIO_MODELS_BUCKET=models
MINIO_SECURE=false

# ── CORS ───────────────────────────────────────────────────
# Local :
#   ALLOWED_ORIGINS=["http://localhost:3000"]
# Production :
#   ALLOWED_ORIGINS=["https://legacy-platform.vercel.app"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Email (SMTP Gmail) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_app_password_gmail
EMAIL_FROM=votre_email@gmail.com
FRONTEND_URL=http://localhost:3000

# ── HuggingFace (optionnel) ────────────────────────────────
HF_API_KEY=
